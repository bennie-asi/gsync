<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.InspectorPanel"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Padding="16"
        Background="{StaticResource AppSurfaceBrush}"
        BorderThickness="0"
        CornerRadius="8">
        <StackPanel Spacing="10">
            <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding Title, ElementName=Root}" />
            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,1,0,0" Opacity="0.55" />
            <ContentPresenter Content="{Binding PanelContent, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>
