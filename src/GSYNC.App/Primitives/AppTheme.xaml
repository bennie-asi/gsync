<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="AppPagePadding">22</Thickness>
    <Thickness x:Key="AppInlinePadding">10,8</Thickness>
    <Thickness x:Key="AppPanelPadding">14</Thickness>
    <CornerRadius x:Key="AppCornerRadius">8</CornerRadius>
    <x:Double x:Key="AppCompactPaneLength">54</x:Double>
    <x:Double x:Key="AppOpenPaneLength">208</x:Double>
    <x:Double x:Key="AppNavRailWidth">104</x:Double>
    <GridLength x:Key="AppNavRailColumnWidth">104</GridLength>
    <x:Double x:Key="AppNavRailButtonWidth">84</x:Double>
    <x:Double x:Key="AppNavRailIconSlotSize">20</x:Double>
    <x:Double x:Key="AppTitleBarHeight">46</x:Double>
    <x:Double x:Key="AppDenseRowHeight">36</x:Double>
    <x:Double x:Key="AppSectionSpacing">14</x:Double>

    <FontFamily x:Key="AppFontFamily">Inter, Segoe UI, Microsoft YaHei UI</FontFamily>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF0B0E17" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF131929" />
    <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#FF151C2D" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#FF101624" />
    <SolidColorBrush x:Key="AppInputBrush" Color="#FF0F1522" />
    <SolidColorBrush x:Key="AppDividerBrush" Color="#886B7592" />
    <SolidColorBrush x:Key="AppPrimaryBrush" Color="#FF5B8CFF" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="#FFA5D6A7" />
    <SolidColorBrush x:Key="AppWarningBrush" Color="#FFFFB74D" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#FFEE7D77" />
    <SolidColorBrush x:Key="AppMutedBrush" Color="#FF95A0BE" />
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#FFE8EDF8" />
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#FFB3BDD6" />
    <SolidColorBrush x:Key="AppTextDimBrush" Color="#FF8994AE" />

    <SolidColorBrush x:Key="BadgeSyncedBrush" Color="#FFA5D6A7" />
    <SolidColorBrush x:Key="BadgeLocalNewerBrush" Color="#FFFFB74D" />
    <SolidColorBrush x:Key="BadgeRemoteNewerBrush" Color="#FF8FB3FF" />
    <SolidColorBrush x:Key="BadgeConflictBrush" Color="#FFEE7D77" />
    <SolidColorBrush x:Key="BadgePendingBrush" Color="#FFFFB74D" />
    <SolidColorBrush x:Key="BadgeMissingBrush" Color="#FF8D97B3" />
    <SolidColorBrush x:Key="BadgeDisabledBrush" Color="#FF6B7592" />
    <SolidColorBrush x:Key="BadgeReadyBrush" Color="#FF5B8CFF" />

    <Style TargetType="Page">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="RailNavButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Width" Value="{StaticResource AppNavRailButtonWidth}" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Padding" Value="6,8" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}" />
        <Setter Property="Foreground" Value="#FF0B0E17" />
    </Style>

    <Style x:Key="SecondaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="{StaticResource AppInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
    </Style>
</ResourceDictionary>
