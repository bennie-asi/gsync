<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.SnapshotFeed"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled"
        MaxHeight="{Binding ContentMaxHeight, ElementName=Root}">
        <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0,0,0,10" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding Detail}" TextWrapping="WrapWholeWords" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding Timestamp}" />
                                <Button Grid.Column="1" Content="Restore" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
