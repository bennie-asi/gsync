<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.AppTitleBar"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Opacity="0.85">
        <Grid Height="48" Padding="16,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding Title, ElementName=Root}" />
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding Subtitle, ElementName=Root}" TextTrimming="CharacterEllipsis" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon FontFamily="{StaticResource MaterialSymbolsFont}" FontSize="15" Foreground="{StaticResource AppTextDimBrush}" Glyph="{StaticResource IconSync}" IsTextScaleFactorEnabled="False" />
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding StatusText, ElementName=Root}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
