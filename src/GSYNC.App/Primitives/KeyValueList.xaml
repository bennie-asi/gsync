<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.KeyValueList"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled"
        MaxHeight="{Binding ContentMaxHeight, ElementName=Root}">
        <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="0,0,0,8">
                        <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding Label}" />
                        <TextBlock FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
