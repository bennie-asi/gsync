<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.DenseDataGrid"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Padding="16"
        Background="{StaticResource AppSurfaceBrush}"
        BorderThickness="0"
        CornerRadius="8">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title, ElementName=Root}" />
            <TextBlock Grid.Row="1" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding Subtitle, ElementName=Root}" TextWrapping="WrapWholeWords" />
            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Auto"
                HorizontalScrollMode="Enabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled"
                ZoomMode="Disabled">
                <ContentPresenter Content="{Binding GridContent, ElementName=Root}" />
            </ScrollViewer>
            <TextBlock Grid.Row="3" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding FooterText, ElementName=Root}" />
        </Grid>
    </Border>
</UserControl>
