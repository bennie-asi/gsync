<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.SearchField"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        x:Name="SearchContainer"
        MinWidth="220"
        Height="34"
        Padding="12,6"
        Background="{StaticResource AppInputBrush}"
        BorderBrush="{StaticResource AppDividerBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid ColumnSpacing="10" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <FontIcon
                x:Name="SearchIcon"
                Width="14"
                Height="14"
                VerticalAlignment="Center"
                Foreground="{StaticResource AppTextDimBrush}"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                Glyph="&#xE721;"
                IsTextScaleFactorEnabled="False" />

            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="1"
                MinHeight="20"
                Height="20"
                Margin="0,-1,0,0"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource AppTextPrimaryBrush}"
                PlaceholderText="{Binding PlaceholderText, ElementName=Root}"
                Style="{StaticResource DefaultTextBoxStyle}"
                Text="{Binding Text, ElementName=Root, Mode=TwoWay}"
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                GotFocus="SearchTextBox_GotFocus"
                LostFocus="SearchTextBox_LostFocus">
                <TextBox.Resources>
                    <x:Double x:Key="TextControlThemeMinHeight">20</x:Double>
                    <Thickness x:Key="TextControlThemePadding">0,0,0,1</Thickness>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#00FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#00FFFFFF" />
                </TextBox.Resources>
            </TextBox>
        </Grid>
    </Border>
</UserControl>
