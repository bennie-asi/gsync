<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.ResizableTableView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16" Background="{StaticResource AppSurfaceBrush}" CornerRadius="8">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleTextBlock" FontSize="18" FontWeight="SemiBold" Text="{Binding Title, ElementName=Root}" Visibility="Collapsed" />
            <TextBlock x:Name="SubtitleTextBlock" Grid.Row="1" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding Subtitle, ElementName=Root}" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
            <ScrollViewer x:Name="TableScrollViewer" Grid.Row="2" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" ViewChanged="TableScrollViewer_ViewChanged">
                <StackPanel>
                    <Grid x:Name="HeaderGrid" Padding="0,0,0,8" ColumnSpacing="12" />
                    <StackPanel x:Name="RowsPanel" Spacing="0" />
                </StackPanel>
            </ScrollViewer>
            <TextBlock x:Name="FooterTextBlock" Grid.Row="3" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding FooterText, ElementName=Root}" Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
