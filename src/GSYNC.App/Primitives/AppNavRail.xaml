<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.AppNavRail"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="8,0,0,8">
        <Grid Padding="10,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="GSYNC" />
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="6" VerticalAlignment="Top">
                <Button x:Name="LibraryButton" Tag="library" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Library" />
                        <TextBlock x:Name="LibraryTextBlock" FontSize="11" Text="Library" />
                    </StackPanel>
                </Button>
                <Button x:Name="TargetsButton" Tag="targets" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Globe" />
                        <TextBlock x:Name="TargetsTextBlock" FontSize="11" Text="Targets" />
                    </StackPanel>
                </Button>
                <Button x:Name="VariablesButton" Tag="variables" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Map" />
                        <TextBlock x:Name="VariablesTextBlock" FontSize="11" Text="Variables" />
                    </StackPanel>
                </Button>
                <Button x:Name="HistoryButton" Tag="history" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Document" />
                        <TextBlock x:Name="HistoryTextBlock" FontSize="11" Text="History" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button Grid.Row="2" x:Name="SettingsButton" Tag="settings" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <SymbolIcon Symbol="Setting" />
                    <TextBlock x:Name="SettingsTextBlock" FontSize="11" Text="Settings" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
