<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.AppNavRail"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,1,0">
        <Grid Padding="12,14,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center" Spacing="6">
                <Border
                    Width="40"
                    Height="40"
                    Background="{StaticResource AppPrimaryBrush}"
                    CornerRadius="8"
                    HorizontalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AppBackgroundBrush}"
                        Text="G" />
                </Border>

                <StackPanel Spacing="1">
                    <TextBlock HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextPrimaryBrush}" Text="GSYNC" />
                    <TextBlock x:Name="AppVersionTextBlock" HorizontalAlignment="Center" FontSize="9" Foreground="{StaticResource AppTextDimBrush}" Text="v1.0.2" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8" VerticalAlignment="Top">
                <Button x:Name="LibraryButton" Tag="library" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Library" />
                        <TextBlock x:Name="LibraryTextBlock" FontSize="10" Text="Library" />
                    </StackPanel>
                </Button>
                <Button x:Name="TargetsButton" Tag="targets" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Globe" />
                        <TextBlock x:Name="TargetsTextBlock" FontSize="10" Text="Targets" />
                    </StackPanel>
                </Button>
                <Button x:Name="VariablesButton" Tag="variables" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Map" />
                        <TextBlock x:Name="VariablesTextBlock" FontSize="10" Text="Variables" />
                    </StackPanel>
                </Button>
                <Button x:Name="HistoryButton" Tag="history" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <SymbolIcon Symbol="Document" />
                        <TextBlock x:Name="HistoryTextBlock" FontSize="10" Text="History" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button Grid.Row="2" x:Name="SettingsButton" Tag="settings" Click="NavButton_Click" Style="{StaticResource RailNavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <SymbolIcon Symbol="Setting" />
                    <TextBlock x:Name="SettingsTextBlock" FontSize="10" Text="Settings" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
