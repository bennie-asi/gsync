<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Material Symbols (Outlined) icon set, sourced from the Stitch design system.
        The bundled variable font (Assets/Fonts/MaterialSymbolsOutlined.ttf, Apache-2.0)
        exposes every Material Symbol, so adding a new icon only needs a new glyph key
        below. Look up the codepoint in Assets/Fonts/MaterialSymbolsOutlined.codepoints
        (format: "<name> <hex>") and add a <x:String> entry as &#x<HEX>;.

        Usage:
            <FontIcon Style="{StaticResource AppIcon}" Glyph="{StaticResource IconLibrary}" />
    -->

    <FontFamily x:Key="MaterialSymbolsFont">ms-appx:///Assets/Fonts/MaterialSymbolsOutlined.ttf#Material Symbols Outlined</FontFamily>

    <!-- Foreground is intentionally left unset so icons inherit the surrounding
         text color (e.g. nav-rail selection state). Override Foreground per-icon
         for status colors like warning/danger. -->
    <Style x:Key="AppIcon" TargetType="FontIcon">
        <Setter Property="FontFamily" Value="{StaticResource MaterialSymbolsFont}" />
        <Setter Property="FontSize" Value="20" />
    </Style>

