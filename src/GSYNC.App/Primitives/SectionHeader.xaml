<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.SectionHeader"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="4">
        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title, ElementName=Root}" />
        <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding Subtitle, ElementName=Root}" TextWrapping="WrapWholeWords" />
    </StackPanel>
</UserControl>
