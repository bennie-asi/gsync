<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.IconText"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel
        Orientation="Horizontal"
        Spacing="{Binding Spacing, ElementName=Root}"
        VerticalAlignment="Center"
        HorizontalAlignment="Center">
        <FontIcon
            x:Name="GlyphIcon"
            FontFamily="{StaticResource MaterialSymbolsFont}"
            FontSize="{Binding GlyphSize, ElementName=Root}"
            Glyph="{Binding Glyph, ElementName=Root}"
            VerticalAlignment="Center"
            IsTextScaleFactorEnabled="False" />
        <TextBlock
            x:Name="LabelText"
            Text="{Binding Text, ElementName=Root}"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
    </StackPanel>
</UserControl>
