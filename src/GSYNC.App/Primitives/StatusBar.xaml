<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.StatusBar"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="12,6" Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,1,0,0" Opacity="0.96">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding WebDavStatusText, ElementName=Root}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding LocalStatusText, ElementName=Root}" TextTrimming="CharacterEllipsis" />
            <Rectangle Grid.Column="2" />
            <TextBlock Grid.Column="3" FontSize="10" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding TargetNameText, ElementName=Root}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="4" FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding SyncStatusText, ElementName=Root}" TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</UserControl>
