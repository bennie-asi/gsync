<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.WizardStepRail"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="8">
        <Grid Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <ContentPresenter Content="{Binding RailContent, ElementName=Root}" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
