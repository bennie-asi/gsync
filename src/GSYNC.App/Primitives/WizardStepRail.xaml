<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GSYNC.App.Primitives.WizardStepRail"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="8">
        <Grid Padding="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="Wizard Progress" />
            <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <ContentPresenter Content="{Binding RailContent, ElementName=Root}" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
