<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.HomePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="LibraryStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind LocalStatus}" Variant="{x:Bind LocalStatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryRemoteStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind RemoteStatus}" Variant="{x:Bind RemoteStatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryActionCellTemplate" x:DataType="vm:LibraryGameRow">
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="{Binding ElementName=RootPage, Path=ViewModel.OpenButtonText}" Click="OpenGameDetails_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="1" Content="{Binding ElementName=RootPage, Path=ViewModel.MoreButtonText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="LibraryPropertyRowTemplate">
            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Opacity="0.85" Padding="0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Text="{Binding Value}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="16" ColumnSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="820" />
            <ColumnDefinition Width="292" MinWidth="272" />
        </Grid.ColumnDefinitions>

        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <primitives:SearchField
                    x:Name="SearchBoxControl"
                    HorizontalAlignment="Left"
                    MaxWidth="460"
                    MinWidth="340"
                    PlaceholderText="Search games"
                    Text="{Binding SearchText, Mode=TwoWay}" />

                <Button
                    x:Name="SortButton"
                    Grid.Column="1"
                    Content="Sort"
                    Style="{StaticResource SecondaryToolbarButtonStyle}" />

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="2"
                    Content="Refresh"
                    Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>

            <primitives:ResizableTableView
                x:Name="LibraryTable"
                Grid.Row="1"
                ItemsSource="{Binding Games}"
                PersistedStateKey="library-main-table" />
        </Grid>

        <Grid Grid.Column="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="AddGameButton"
                    Content="Add Game"
                    Click="OpenAddGameWizard_Click"
                    Style="{StaticResource SecondaryToolbarButtonStyle}" />

                <Button
                    x:Name="SyncNowButton"
                    Grid.Column="1"
                    Content="Sync Now"
                    Style="{StaticResource PrimaryToolbarButtonStyle}" />
            </Grid>

            <primitives:PropertySheet x:Name="OverviewSheet" Grid.Row="1" Title="Overview">
                <primitives:PropertySheet.PanelContent>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                        <StackPanel Spacing="10">
                            <ItemsControl ItemTemplate="{StaticResource LibraryPropertyRowTemplate}" ItemsSource="{Binding OverviewMetrics}" />
                            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,1,0,0" Opacity="0.55" Margin="0,4,0,0" />
                            <ItemsControl ItemTemplate="{StaticResource LibraryPropertyRowTemplate}" ItemsSource="{Binding Stats}" />
                        </StackPanel>
                    </ScrollViewer>
                </primitives:PropertySheet.PanelContent>
            </primitives:PropertySheet>
        </Grid>
    </Grid>
</Page>
