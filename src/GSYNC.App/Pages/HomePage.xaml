<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.HomePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="LibraryStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind LocalStatus}" Variant="{x:Bind LocalStatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryRemoteStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind RemoteStatus}" Variant="{x:Bind RemoteStatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryActionCellTemplate" x:DataType="vm:LibraryGameRow">
            <Grid ColumnSpacing="4" MinWidth="152">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Padding="8,4" MinHeight="28" Content="{Binding ElementName=RootPage, Path=ViewModel.OpenButtonText}" Click="OpenGameDetails_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="1" Padding="8,4" MinHeight="28" Content="{Binding ElementName=RootPage, Path=ViewModel.MoreButtonText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="LibraryPropertyRowTemplate">
            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Opacity="0.85" Padding="0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Text="{Binding Value}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid x:Name="MainContentRoot" Padding="16" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="820" />
                <ColumnDefinition Width="292" MinWidth="272" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <primitives:SearchField
                        x:Name="SearchBoxControl"
                        HorizontalAlignment="Left"
                        MaxWidth="460"
                        MinWidth="340"
                        PlaceholderText="Search games"
                        Text="{Binding SearchText, Mode=TwoWay}" />

                    <Button
                        x:Name="SortButton"
                        Grid.Column="1"
                        Content="Sort"
                        Style="{StaticResource SecondaryToolbarButtonStyle}" />

                    <Button
                        x:Name="RefreshButton"
                        Grid.Column="2"
                        Content="Refresh"
                        Style="{StaticResource SecondaryToolbarButtonStyle}" />
                </Grid>

                <primitives:ResizableTableView
                    x:Name="LibraryTable"
                    Grid.Row="1"
                    ItemsSource="{Binding Games}"
                    PersistedStateKey="library-main-table" />
            </Grid>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="AddGameButton"
                        Content="Add Game"
                        Click="OpenAddGameWizard_Click"
                        Style="{StaticResource SecondaryToolbarButtonStyle}" />

                    <Button
                        x:Name="SyncNowButton"
                        Grid.Column="1"
                        Content="Sync Now"
                        Style="{StaticResource PrimaryToolbarButtonStyle}" />
                </Grid>

                <primitives:PropertySheet x:Name="OverviewSheet" Grid.Row="1" Title="Overview">
                    <primitives:PropertySheet.PanelContent>
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="OverviewSubtitleTextBlock" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            <ItemsControl ItemTemplate="{StaticResource LibraryPropertyRowTemplate}" ItemsSource="{Binding OverviewMetrics}" />
                        </StackPanel>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>

                <primitives:PropertySheet x:Name="ActivitySheet" Grid.Row="2" Title="Activity Timeline">
                    <primitives:PropertySheet.PanelContent>
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="ActivitySubtitleTextBlock" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                            <primitives:ActivityFeed ItemsSource="{Binding Activity}" ContentHeight="320" />
                        </StackPanel>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>
            </Grid>
        </Grid>

        <Border
            x:Name="InitializationErrorPanel"
            MaxWidth="720"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppSurfaceAltBrush}"
            BorderBrush="{StaticResource AppDividerBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <StackPanel Spacing="16">
                <primitives:InfoCallout
                    Title="首页加载失败"
                    Message="Library 页面初始化出现异常，应用已保留主壳层和导航能力。"
                    Severity="Error" />

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="InitializationErrorTitle"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Library 初始化失败" />
                    <TextBlock
                        x:Name="InitializationErrorMessage"
                        Foreground="{StaticResource AppTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Content="重试加载"
                    Click="RetryInitialization_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
