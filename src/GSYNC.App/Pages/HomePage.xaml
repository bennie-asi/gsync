<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.HomePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="LibraryStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind LocalStatus}" Variant="{x:Bind LocalStatus}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryRemoteStatusCellTemplate" x:DataType="vm:LibraryGameRow">
            <primitives:Badge Text="{x:Bind RemoteStatus}" Variant="{x:Bind RemoteStatus}" />
        </DataTemplate>
        <DataTemplate x:Key="LibraryActionCellTemplate" x:DataType="vm:LibraryGameRow">
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="打开" Click="OpenGameDetails_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="1" Content="更多" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <primitives:SectionHeader
            x:Name="PageHeader"
            Title="Game Library"
            Subtitle="Dense multi-game overview with explicit sync state, recent activity, and quick recovery actions." />

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <primitives:ToolbarFilterRow
                x:Name="ToolbarFilters"
                SearchText="{Binding SearchText, Mode=TwoWay}"
                SearchPlaceholder="Search games"
                FilterItems="{Binding StatusFilters}"
                FilterPlaceholder="Status"
                SelectedFilter="{Binding SelectedStatus, Mode=TwoWay}" />

            <Button x:Name="AddGameButton" Grid.Column="1" Content="Add Game" Click="OpenAddGameWizard_Click" Style="{StaticResource PrimaryToolbarButtonStyle}" />
            <Button x:Name="SyncNowButton" Grid.Column="2" Content="Sync Now" Style="{StaticResource SecondaryToolbarButtonStyle}" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.25*" MinWidth="720" />
                <ColumnDefinition Width="352" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <primitives:ResizableTableView
                x:Name="LibraryTable"
                Title="Tracked games"
                Subtitle="Game, source, item count, local state, remote state, last sync, and target remain visible in one dense table."
                FooterText="GSYNC Library · Resolve actions remain inline for conflicts."
                PersistedStateKey="library-main-table"
                ItemsSource="{Binding Games}" />

            <Grid Grid.Column="1" Width="352">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <primitives:PropertySheet x:Name="OverviewSheet" Title="Overview">
                    <primitives:PropertySheet.PanelContent>
                        <ScrollViewer Height="196" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <StackPanel Spacing="12">
                                <ItemsControl ItemsSource="{Binding OverviewMetrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LibraryOverviewMetric">
                                            <Border Width="150" Margin="0,0,10,10" Padding="12" Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{x:Bind Value}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <primitives:KeyValueList ContentMaxHeight="96" ItemsSource="{Binding Stats}" />
                            </StackPanel>
                        </ScrollViewer>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>

                <primitives:InspectorPanel x:Name="ActivityPanel" Grid.Row="2" Title="Activity">
                    <primitives:InspectorPanel.PanelContent>
                        <primitives:ActivityFeed ContentHeight="276" ItemsSource="{Binding Activity}" />
                    </primitives:InspectorPanel.PanelContent>
                </primitives:InspectorPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
