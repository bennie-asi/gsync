<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.AddGameWizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels">
    <Page.Resources>
        <Style x:Key="WizardSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppTextDimBrush}" />
        </Style>
        <DataTemplate x:Key="WizardOptionTemplate" x:DataType="vm:WizardOption">
            <Border Padding="14" Margin="0,0,0,10" Background="{StaticResource AppSurfaceAltBrush}" CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{x:Bind Title}" />
                    <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Summary}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <primitives:SectionHeader Title="{Binding PageTitle}" Subtitle="{Binding PageSubtitle}" />

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <primitives:WizardStepRail>
                <primitives:WizardStepRail.RailContent>
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding WizardRailTitle}" />
                            <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding WizardRailSubtitle}" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WizardStepItem">
                                    <Border Padding="10" Margin="0,0,0,8" Background="{StaticResource AppSurfaceBrush}" CornerRadius="8">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="24" Height="24" Background="{StaticResource AppPrimaryBrush}" CornerRadius="12">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AppBackgroundBrush}" FontWeight="SemiBold" Text="{x:Bind Index}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Summary}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </primitives:WizardStepRail.RailContent>
            </primitives:WizardStepRail>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <StackPanel Spacing="16">
                    <primitives:PropertySheet Title="{Binding CurrentStepTitle}">
                        <primitives:PropertySheet.PanelContent>
                            <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding CurrentStepDescription}" TextWrapping="WrapWholeWords" />
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:DenseDataGrid Title="{Binding SourcesTitle}" Subtitle="{Binding SourcesSubtitle}" FooterText="{Binding CurrentStepFooter}" Visibility="{Binding IsStep1, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <primitives:DenseDataGrid.GridContent>
                            <ItemsControl ItemTemplate="{StaticResource WizardOptionTemplate}" ItemsSource="{Binding Sources}" />
                        </primitives:DenseDataGrid.GridContent>
                    </primitives:DenseDataGrid>

                    <StackPanel Spacing="16" Visibility="{Binding IsStep2, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Visibility="{Binding ShowNoResultsState, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Spacing="14">
                                <primitives:InfoCallout Severity="Warning" Title="{Binding NoResultsTitle}" Message="{Binding NoResultsMessage}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding NoResultsPrimaryActionText}" Click="SwitchToManualSetupButton_Click" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                                    <Button Grid.Column="1" Content="{Binding NoResultsSecondaryActionText}" Click="BackToSourceSelectionButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="16" Visibility="{Binding ShowNoResultsState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <primitives:DenseDataGrid Title="{Binding GamesTitle}" Subtitle="{Binding GamesSubtitle}" FooterText="{Binding CurrentStepFooter}">
                                <primitives:DenseDataGrid.GridContent>
                                    <ItemsControl ItemTemplate="{StaticResource WizardOptionTemplate}" ItemsSource="{Binding Games}" />
                                </primitives:DenseDataGrid.GridContent>
                            </primitives:DenseDataGrid>

                            <primitives:PropertySheet Grid.Column="1" Title="{Binding Step2DetailsTitle}">
                                <primitives:PropertySheet.PanelContent>
                                    <primitives:KeyValueList ItemsSource="{Binding GameDetails}" ContentMaxHeight="220" />
                                </primitives:PropertySheet.PanelContent>
                            </primitives:PropertySheet>
                        </Grid>
                    </StackPanel>

                    <primitives:DenseDataGrid Title="{Binding ContentTitle}" Subtitle="{Binding ContentSubtitle}" FooterText="{Binding CurrentStepFooter}" Visibility="{Binding IsStep3, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <primitives:DenseDataGrid.GridContent>
                            <ItemsControl ItemTemplate="{StaticResource WizardOptionTemplate}" ItemsSource="{Binding ContentItems}" />
                        </primitives:DenseDataGrid.GridContent>
                    </primitives:DenseDataGrid>

                    <primitives:PropertySheet Title="{Binding Step4ReviewTitle}" Visibility="{Binding IsStep4, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <primitives:PropertySheet.PanelContent>
                            <primitives:KeyValueList ItemsSource="{Binding PathReview}" ContentMaxHeight="200" />
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:DenseDataGrid Title="{Binding TargetsTitle}" Subtitle="{Binding TargetsSubtitle}" FooterText="{Binding CurrentStepFooter}" Visibility="{Binding IsStep5, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <primitives:DenseDataGrid.GridContent>
                            <ItemsControl ItemTemplate="{StaticResource WizardOptionTemplate}" ItemsSource="{Binding Targets}" />
                        </primitives:DenseDataGrid.GridContent>
                    </primitives:DenseDataGrid>

                    <primitives:PropertySheet Title="{Binding Step6ReadyTitle}" Visibility="{Binding IsStep6, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="12">
                                <primitives:KeyValueList ItemsSource="{Binding FinishSummary}" ContentMaxHeight="220" />
                                <primitives:InfoCallout Title="{Binding FinishCalloutTitle}" Message="{Binding FinishCalloutMessage}" Severity="Info" />
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding FinishExcludedText}" TextWrapping="WrapWholeWords" />
                                <ItemsControl ItemsSource="{Binding FinishOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="{Binding CancelText}" Click="CancelButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="2" Content="{Binding BackText}" Click="BackButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}" IsEnabled="{Binding CanGoBack}" />
            <Button Grid.Column="3" Content="{Binding NextButtonText}" Click="NextButton_Click" Style="{StaticResource PrimaryToolbarButtonStyle}" />
        </Grid>
    </Grid>
</Page>
