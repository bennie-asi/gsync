<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels">
    <Page.Resources>
        <DataTemplate x:Key="GameMetaRowTemplate" x:DataType="vm:UiGameMetaRow">
            <Border
                Margin="0,0,0,6"
                Background="{StaticResource AppSurfaceAltBrush}"
                BorderBrush="{StaticResource AppDividerBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource AppTextSecondaryBrush}"
                            Text="{x:Bind InstallDirectoryDisplay}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <primitives:Badge Grid.Column="1" Text="{x:Bind SourceLabel}" VerticalAlignment="Center" />
                    <Button
                        Grid.Column="2"
                        Click="GameEditButton_Click"
                        Content="{x:Bind EditButtonText}"
                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SettingGroupTemplate" x:DataType="vm:UiSettingOption">
            <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="28" Height="28" Background="{StaticResource AppSurfaceRaisedBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" VerticalAlignment="Top">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="{x:Bind KeyLabel}" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                        <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Summary}" TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <primitives:Badge Grid.Column="2" Text="{x:Bind Status}" Variant="{x:Bind Variant}" VerticalAlignment="Top" />
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SettingsPropertyTemplate" x:DataType="vm:UiPropertyRow">
            <Grid Padding="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid x:Name="MainContentRoot" Padding="{StaticResource AppPagePadding}" ColumnSpacing="16" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <primitives:SectionHeader Grid.ColumnSpan="3" Title="{Binding PageTitle}" Subtitle="{Binding PageSubtitle}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <primitives:PropertySheet Title="{Binding GroupNavTitle}">
                    <primitives:PropertySheet.PanelContent>
                        <StackPanel Spacing="12">
                            <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding GroupNavSubtitle}" TextWrapping="WrapWholeWords" />
                            <ListView
                                x:Name="GroupsListView"
                                IsItemClickEnabled="True"
                                ItemClick="GroupsListView_ItemClick"
                                ItemsSource="{Binding Groups}"
                                ItemTemplate="{StaticResource SettingGroupTemplate}"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,4" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                            </ListView>
                            <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding GroupNavFooter}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>
            </ScrollViewer>

            <ScrollViewer x:Name="CenterScrollViewer" Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <StackPanel Spacing="16">
                    <primitives:SectionHeader x:Name="AppearanceHeader" Title="{Binding AppearanceTitle}" Subtitle="{Binding AppearanceSubtitle}" />

                    <primitives:PropertySheet x:Name="ThemeBehaviorSheet" Title="Theme and system behavior">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding ThemeBehaviorSubtitle}" TextWrapping="WrapWholeWords" />

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding LanguageLabel}" />
                                    <ComboBox ItemsSource="{Binding SupportedLanguages}" SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ThemeModeLabel}" />
                                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding DensityLabel}" />
                                    <ComboBox ItemsSource="{Binding DensityOptions}" SelectedItem="{Binding SelectedDensityMode, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:PropertySheet x:Name="BehaviorSection" Title="{Binding BehaviorTitle}">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding BehaviorSubtitle}" TextWrapping="WrapWholeWords" />

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding DefaultTargetLabel}" />
                                    <ComboBox ItemsSource="{Binding AvailableTargets}" SelectedItem="{Binding SelectedDefaultTarget, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding AutoSnapshotLabel}" />
                                    <ComboBox ItemsSource="{Binding ToggleOptions}" SelectedItem="{Binding SelectedAutoSnapshotOption, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding RefreshManifestLabel}" />
                                    <ComboBox ItemsSource="{Binding ToggleOptions}" SelectedItem="{Binding SelectedRefreshManifestOption, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ManifestSourceUrlLabel}" />
                                    <TextBox
                                        PlaceholderText="{Binding ManifestSourceUrlPlaceholder}"
                                        Text="{Binding ManifestSourceUrlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:PropertySheet x:Name="LoggingSection" Title="{Binding LoggingTitle}">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="14">
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding LoggingSubtitle}" TextWrapping="WrapWholeWords" />
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding LogLevelLabel}" />
                                    <ComboBox ItemsSource="{Binding LogLevelOptions}" SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}" />
                                </StackPanel>
                                <Button x:Name="OpenLogsDirButton" Click="OpenLogsDirButton_Click" Content="{Binding OpenLogsDirText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:PropertySheet x:Name="DiagnosticsSection" Title="{Binding DiagnosticsTitle}">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding DiagnosticsSubtitle}" TextWrapping="WrapWholeWords" />
                                <ItemsControl ItemTemplate="{StaticResource SettingsPropertyTemplate}" ItemsSource="{Binding Diagnostics}" />
                                <Button x:Name="OpenDataDirButton" Click="OpenDataDirButton_Click" Content="{Binding OpenDataDirText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <primitives:PropertySheet x:Name="GamesSection" Title="{Binding GamesTitle}">
                        <primitives:PropertySheet.PanelContent>
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding GamesSubtitle}" TextWrapping="WrapWholeWords" />
                                <ItemsControl ItemsSource="{Binding GameEntries}" ItemTemplate="{StaticResource GameMetaRowTemplate}" />
                            </StackPanel>
                        </primitives:PropertySheet.PanelContent>
                    </primitives:PropertySheet>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RestoreDefaultsButton" Click="RestoreDefaultsButton_Click" Content="Restore Defaults" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        <Button x:Name="SaveSettingsButton" Grid.Column="2" Click="SaveSettingsButton_Click" Content="Save Settings" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <StackPanel Spacing="12">
                    <primitives:InspectorPanel Title="{Binding PreviewHeader}">
                        <primitives:InspectorPanel.PanelContent>
                            <StackPanel Spacing="12">
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding PreviewSubtitle}" TextWrapping="WrapWholeWords" />

                                <primitives:PropertySheet Title="{Binding PreviewSectionTitle}">
                                    <primitives:PropertySheet.PanelContent>
                                        <StackPanel Spacing="10">
                                            <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding PreviewSectionSubtitle}" TextWrapping="WrapWholeWords" />
                                            <ItemsControl ItemsSource="{Binding PreviewRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:UiPreviewRow">
                                                        <Border Padding="0,0,0,10" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1">
                                                            <StackPanel Spacing="6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                                    <primitives:Badge Grid.Column="1" Text="{x:Bind Status}" Variant="{x:Bind Variant}" />
                                                                </Grid>
                                                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Path}" TextWrapping="WrapWholeWords" />
                                                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Summary}" TextWrapping="WrapWholeWords" />
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Click="PreviewPrimaryActionButton_Click" Content="{x:Bind PrimaryActionText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                                                    <Button Grid.Column="1" Margin="8,0,0,0" Click="PreviewSecondaryActionButton_Click" Content="{x:Bind SecondaryActionText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </primitives:PropertySheet.PanelContent>
                                </primitives:PropertySheet>
                            </StackPanel>
                        </primitives:InspectorPanel.PanelContent>
                    </primitives:InspectorPanel>

                    <Button x:Name="AddNewTargetButton" Click="AddNewTargetButton_Click" Content="Add New Target" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border
            x:Name="InitializationErrorPanel"
            MaxWidth="720"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppSurfaceAltBrush}"
            BorderBrush="{StaticResource AppDividerBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <StackPanel Spacing="16">
                <primitives:InfoCallout
                    Title="设置页加载失败"
                    Message="Settings 页面初始化出现异常，应用已保留主壳层和其他导航能力。"
                    Severity="Error" />

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="InitializationErrorTitle"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Settings 初始化失败" />
                    <TextBlock
                        x:Name="InitializationErrorMessage"
                        Foreground="{StaticResource AppTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Content="重试加载"
                    Click="RetryInitialization_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
