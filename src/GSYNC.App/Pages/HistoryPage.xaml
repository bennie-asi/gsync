<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels">
    <Page.Resources>
        <DataTemplate x:Key="HistoryResultTemplate" x:DataType="vm:HistoryRow">
            <primitives:Badge Text="{x:Bind Result}" Variant="{x:Bind ResultVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="RecordDetailRowTemplate" x:DataType="vm:UiPropertyRow">
            <Grid Padding="0,4" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Top" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                <TextBlock Grid.Column="1" FontFamily="Consolas" HorizontalAlignment="Right" TextAlignment="Right" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="EmptyStateRecoveryStepTemplate">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Foreground="{StaticResource AppPrimaryBrush}" Text="•" />
                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid x:Name="MainContentRoot" Padding="{StaticResource AppPagePadding}" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <primitives:SearchField Width="220" PlaceholderText="{Binding SearchPlaceholder}" Text="{Binding SearchText, Mode=TwoWay}" />
                    <primitives:FilterDropdown Width="150" ItemsSource="{Binding GameFilters}" Placeholder="{Binding GameFilterPlaceholder}" SelectedItem="{Binding SelectedGameFilter, Mode=TwoWay}" />
                    <primitives:FilterDropdown Width="150" ItemsSource="{Binding ResultFilters}" Placeholder="{Binding ResultFilterPlaceholder}" SelectedItem="{Binding SelectedResultFilter, Mode=TwoWay}" />
                    <primitives:FilterDropdown Width="150" ItemsSource="{Binding TimeRangeFilters}" Placeholder="{Binding TimeRangePlaceholder}" SelectedItem="{Binding SelectedHistoryFilter, Mode=TwoWay}" />
                </StackPanel>

                <Button Grid.Column="1" Click="RefreshButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                    <primitives:IconText Glyph="{StaticResource IconRefresh}" Text="{Binding RefreshButtonText}" />
                </Button>
                <Button Grid.Column="2" Click="RestoreLatestSnapshotButton_Click" IsEnabled="{Binding CanRestore}" Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <primitives:IconText Glyph="{StaticResource IconRestore}" Text="{Binding RestoreSnapshotButtonText}" />
                </Button>
                <Button Grid.Column="3" Click="OpenLogsButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                    <primitives:IconText Glyph="{StaticResource IconDescription}" Text="{Binding LogsButtonText}" />
                </Button>
                <Button Grid.Column="4" Click="OpenHelpButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                    <primitives:IconText Glyph="{StaticResource IconHelp}" Text="{Binding HelpButtonText}" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="720" />
                    <ColumnDefinition Width="360" MinWidth="320" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <primitives:ResizableTableView
                        x:Name="HistoryTable"
                        FooterText="{Binding SystemStatus}"
                        ItemsSource="{Binding Entries}"
                        PersistedStateKey="history-main-table"
                        Subtitle="{Binding TableSubtitle}"
                        Title="{Binding TableTitle}"
                        Visibility="{Binding IsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />

                    <Border
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Visibility="{Binding IsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Spacing="16">
                            <primitives:InfoCallout Severity="Info" Title="{Binding EmptyStateTitle}" Message="{Binding EmptyStateMessage}" />
                            <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding EmptyStateHint}" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="GoToLibraryButton_Click" Style="{StaticResource PrimaryToolbarButtonStyle}">
                                    <primitives:IconText Glyph="{StaticResource IconLibrary}" Text="{Binding EmptyStateActionText}" />
                                </Button>
                                <Button Click="OpenLogsButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                    <primitives:IconText Glyph="{StaticResource IconDescription}" Text="{Binding EmptyStateSecondaryActionText}" />
                                </Button>
                            </StackPanel>
                            <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding SystemStatus}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Background="{StaticResource AppSurfaceBrush}" Padding="12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding DetailTitle}" />
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding DetailSubtitle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Visibility="{Binding IsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding DetailRecordId}" />
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <Grid>
                                <StackPanel Spacing="14" Visibility="{Binding IsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                    <primitives:PropertySheet Title="{Binding DetailSummaryTitle}">
                                        <primitives:PropertySheet.PanelContent>
                                            <StackPanel Spacing="10">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding DetailGameName}" />
                                                    <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding DetailSummarySubtitle}" TextWrapping="WrapWholeWords" />
                                                    <primitives:Badge Text="{Binding DetailStatus}" Variant="{Binding DetailStatusVariant}" />
                                                </StackPanel>
                                                <ItemsControl ItemTemplate="{StaticResource RecordDetailRowTemplate}" ItemsSource="{Binding RecordDetails}" />
                                            </StackPanel>
                                        </primitives:PropertySheet.PanelContent>
                                    </primitives:PropertySheet>

                                    <primitives:PropertySheet Title="{Binding SnapshotsTitle}">
                                        <primitives:PropertySheet.PanelContent>
                                            <StackPanel Spacing="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding SnapshotsSubtitle}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock Grid.Column="1" FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding SnapshotGameLabel}" />
                                                </Grid>
                                                <primitives:SnapshotFeed ActionInvoked="SnapshotFeed_ActionInvoked" ActionText="{Binding RestoreActionText}" ContentMaxHeight="280" ItemsSource="{Binding Snapshots}" />
                                            </StackPanel>
                                        </primitives:PropertySheet.PanelContent>
                                    </primitives:PropertySheet>
                                </StackPanel>

                                <StackPanel Spacing="14" Visibility="{Binding IsEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <primitives:InfoCallout Severity="Info" Title="{Binding EmptyStateInspectorTitle}" Message="{Binding EmptyStateInspectorMessage}" />
                                    <primitives:PropertySheet Title="{Binding EmptyStateRecoveryTitle}">
                                        <primitives:PropertySheet.PanelContent>
                                            <ItemsControl ItemTemplate="{StaticResource EmptyStateRecoveryStepTemplate}" ItemsSource="{Binding EmptyStateRecoverySteps}" />
                                        </primitives:PropertySheet.PanelContent>
                                    </primitives:PropertySheet>
                                    <primitives:PropertySheet Title="{Binding SnapshotsTitle}">
                                        <primitives:PropertySheet.PanelContent>
                                            <StackPanel Spacing="8">
                                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding SystemStatus}" TextWrapping="WrapWholeWords" />
                                                <primitives:SnapshotFeed ActionInvoked="SnapshotFeed_ActionInvoked" ActionText="{Binding RestoreActionText}" ContentMaxHeight="220" ItemsSource="{Binding Snapshots}" />
                                            </StackPanel>
                                        </primitives:PropertySheet.PanelContent>
                                    </primitives:PropertySheet>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Blocks interaction while a snapshot restore runs so it stays atomic and double-clicks are ignored. -->
            <Border
                Grid.RowSpan="2"
                Background="#B0000000"
                Visibility="{Binding IsRestoreInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <ProgressRing Width="28" Height="28" IsActive="{Binding IsRestoreInProgress}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextPrimaryBrush}"
                        Text="{Binding RestoringText}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            x:Name="InitializationErrorPanel"
            MaxWidth="720"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppSurfaceAltBrush}"
            BorderBrush="{StaticResource AppDividerBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <StackPanel Spacing="16">
                <primitives:InfoCallout
                    Title="历史页加载失败"
                    Message="History 页面初始化出现异常，应用仍可继续导航到其他页面。"
                    Severity="Error" />

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="InitializationErrorTitle"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="History 初始化失败" />
                    <TextBlock
                        x:Name="InitializationErrorMessage"
                        Foreground="{StaticResource AppTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Click="RetryInitialization_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}">
                    <primitives:IconText Glyph="{StaticResource IconRefresh}" Text="重试加载" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
