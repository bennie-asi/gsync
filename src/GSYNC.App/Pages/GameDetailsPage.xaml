<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.GameDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="ContentItemStatusTemplate" x:DataType="vm:ContentItemRow">
            <primitives:Badge Text="{x:Bind Status}" Variant="{x:Bind StatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="ContentItemToggleTemplate" x:DataType="vm:ContentItemRow">
            <ToggleSwitch HorizontalAlignment="Right" IsEnabled="False" IsOn="{Binding Enabled, Mode=OneWay}" OffContent="" OnContent="" MinWidth="44" />
        </DataTemplate>
        <DataTemplate x:Key="SidebarFieldTemplate" x:DataType="vm:UiPropertyRow">
            <StackPanel Spacing="6">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" TextTrimming="CharacterEllipsis" />
                <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <TextBlock FontSize="12" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                </Border>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="HistoryRowTemplate" x:DataType="vm:GameHistoryRow">
            <Grid Padding="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="86" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Timestamp}" />
                <primitives:Badge Grid.Column="1" Text="{x:Bind ActionText}" Variant="{x:Bind ActionVariant}" />
                <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{x:Bind SummaryText}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" HorizontalAlignment="Right" Text="{x:Bind SizeText}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="{Binding UploadText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="1" Content="{Binding DownloadText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="2" Click="OpenConflictResolution_Click" Content="{Binding CompareText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="4" Content="{Binding RestoreText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="860" />
                <ColumnDefinition Width="320" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Height="116" Width="84">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontWeight="SemiBold" Text="ER" />
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
                                <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding AppIdText}" />
                                </Border>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding StudioText}" />
                                <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="•" />
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding LastPlayedText}" />
                            </StackPanel>

                            <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding OverallStatusLabel}" />
                                        <primitives:Badge Text="{Binding OverallStatusText}" Variant="{Binding OverallStatusVariant}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TotalSizeLabel}" />
                                        <TextBlock FontFamily="Consolas" Text="{Binding TotalSizeText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ActiveTargetLabel}" />
                                        <TextBlock Text="{Binding ActiveTarget}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TableSectionTitle}" />
                            <Button Grid.Column="1" Content="{Binding AddItemText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        </Grid>
                    </Border>

                    <primitives:ResizableTableView
                        x:Name="ContentItemsTable"
                        Grid.Row="1"
                        FooterText="{Binding TableFooterText}"
                        ItemsSource="{Binding ContentItems}"
                        PersistedStateKey="game-details-content-table"
                        Subtitle="{Binding TableSubtitle}"
                        Title="{Binding TableTitle}" />
                </Grid>

                <Border Grid.Row="2" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Background="{StaticResource AppSurfaceAltBrush}" ColumnSpacing="18" Padding="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="{Binding HistoryTabText}" HorizontalAlignment="Left" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            <Button Grid.Column="1" Content="{Binding SnapshotsTabText}" HorizontalAlignment="Left" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        </Grid>

                        <ScrollViewer Grid.Row="1" Padding="12,8" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <ItemsControl ItemTemplate="{StaticResource HistoryRowTemplate}" ItemsSource="{Binding RecentHistory}" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Background="{StaticResource AppSurfaceBrush}" Padding="12,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding PropertiesTitle}" />
                        <Button Grid.Column="1" Content="×" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding OpenFolderText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                <Button Grid.Column="1" Content="{Binding TestPathText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </Grid>

                            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,1,0,0" Opacity="0.55" Margin="0,2,0,0" />
                            <ItemsControl ItemTemplate="{StaticResource SidebarFieldTemplate}" ItemsSource="{Binding SelectedItemProperties}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
