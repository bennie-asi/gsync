<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.GameDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="ContentItemStatusTemplate">
            <primitives:Badge Text="{Binding Status}" Variant="{Binding Status}" />
        </DataTemplate>
        <DataTemplate x:Key="ContentItemToggleTemplate">
            <CheckBox HorizontalAlignment="Left" IsChecked="{Binding Enabled, Mode=OneWay}" VerticalAlignment="Center" />
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <primitives:SectionHeader Title="{Binding Title}" Subtitle="{Binding PageSubtitle}" />

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Content="{Binding SyncText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="1" Content="{Binding UploadText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
            <Button Grid.Column="2" Content="{Binding DownloadText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="3" Click="OpenConflictResolution_Click" Content="{Binding CompareText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            <Button Grid.Column="4" Content="{Binding RestoreText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
        </Grid>

        <primitives:PropertySheet Grid.Row="2" Title="{Binding SummaryTitle}">
            <primitives:PropertySheet.PanelContent>
                <ItemsControl ItemsSource="{Binding OverviewFacts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,20,8" Width="170">
                                <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding Label}" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding Value}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </primitives:PropertySheet.PanelContent>
        </primitives:PropertySheet>

        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.75*" MinWidth="700" />
                <ColumnDefinition Width="360" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <primitives:ResizableTableView
                x:Name="ContentItemsTable"
                Title="{Binding TableTitle}"
                Subtitle="{Binding TableSubtitle}"
                FooterText="{Binding TableFooterText}"
                PersistedStateKey="game-details-content-table"
                ItemsSource="{Binding ContentItems}" />

            <StackPanel Grid.Column="1" Spacing="12">
                <Button Content="{Binding AddItemText}" HorizontalAlignment="Left" Style="{StaticResource SecondaryToolbarButtonStyle}" />

                <primitives:PropertySheet Title="{Binding PropertiesTitle}">
                    <primitives:PropertySheet.PanelContent>
                        <primitives:KeyValueList ItemsSource="{Binding SelectedItemProperties}" ContentMaxHeight="260" />
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>

                <primitives:InspectorPanel Title="{Binding ActivityTitle}">
                    <primitives:InspectorPanel.PanelContent>
                        <primitives:ActivityFeed ContentHeight="220" ItemsSource="{Binding RecentActivity}" />
                    </primitives:InspectorPanel.PanelContent>
                </primitives:InspectorPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
