<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.GameDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="ContentItemStatusTemplate" x:DataType="vm:ContentItemRow">
            <primitives:Badge Text="{x:Bind Status}" Variant="{x:Bind StatusVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="ContentItemToggleTemplate" x:DataType="vm:ContentItemRow">
            <primitives:Badge Text="{x:Bind EnabledText}" Variant="{x:Bind EnabledVariant}" />
        </DataTemplate>
        <DataTemplate x:Key="ContextMetricTemplate" x:DataType="vm:UiPropertyRow">
            <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <primitives:SectionHeader Title="{Binding Title}" Subtitle="{Binding PageSubtitle}" />

            <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding PrimaryActionLabel}" HorizontalAlignment="Right" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Click="UploadButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                        <primitives:IconText Glyph="{StaticResource IconUpload}" Text="{Binding UploadText}" />
                    </Button>
                    <Button Grid.Column="1" Click="DownloadButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                        <primitives:IconText Glyph="{StaticResource IconDownload}" Text="{Binding DownloadText}" />
                    </Button>
                    <Button Grid.Column="2" Click="OpenConflictResolution_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                        <primitives:IconText Glyph="{StaticResource IconCompareArrows}" Text="{Binding CompareText}" />
                    </Button>
                    <Button Grid.Column="3" Click="RestoreButton_Click" Style="{StaticResource PrimaryToolbarButtonStyle}">
                        <primitives:IconText Glyph="{StaticResource IconRestore}" Text="{Binding RestoreText}" />
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="860" />
                    <ColumnDefinition Width="320" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="260" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Height="118" Width="92">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="ER" />
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Title}" />
                                <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding AppIdText}" />
                                </Border>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding StudioText}" />
                                <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="•" />
                                <TextBlock Foreground="{StaticResource AppTextSecondaryBrush}" Text="{Binding LastPlayedText}" />
                            </StackPanel>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ItemsControl ItemTemplate="{StaticResource ContextMetricTemplate}" ItemsSource="{Binding OverviewMetrics}" Grid.ColumnSpan="4" />
                            </Grid>

                            <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding OverallStatusLabel}" />
                                        <primitives:Badge Text="{Binding OverallStatusText}" Variant="{Binding OverallStatusVariant}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TotalSizeLabel}" />
                                        <TextBlock FontFamily="Consolas" Text="{Binding TotalSizeText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ActiveTargetLabel}" />
                                        <TextBlock Text="{Binding ActiveTarget}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding TableSectionTitle}" />
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TableSectionSubtitle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Click="NotYetEditableButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                <primitives:IconText Glyph="{StaticResource IconAdd}" GlyphSize="16" Text="{Binding AddItemText}" />
                            </Button>
                        </Grid>
                    </Border>

                    <primitives:ResizableTableView
                        x:Name="ContentItemsTable"
                        Grid.Row="1"
                        FooterText="{Binding TableFooterText}"
                        ItemsSource="{Binding ContentItems}"
                        PersistedStateKey="game-details-content-table"
                        Subtitle="{Binding TableSubtitle}"
                        Title="{Binding TableTitle}" />
                </Grid>

                <Border Grid.Row="2" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding HistorySectionTitle}" />
                                <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding HistorySectionSubtitle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <Button Grid.Column="1" Click="OpenActivityInfoButton_Click" HorizontalAlignment="Left" Style="{StaticResource PrimaryToolbarButtonStyle}">
                                <primitives:IconText Glyph="{StaticResource IconHistory}" GlyphSize="16" Text="{Binding HistoryTabText}" />
                            </Button>
                            <Button Grid.Column="2" Margin="8,0,0,0" Click="OpenSnapshotInfoButton_Click" HorizontalAlignment="Left" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                <primitives:IconText Glyph="{StaticResource IconSave}" GlyphSize="16" Text="{Binding SnapshotsTabText}" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <primitives:PropertySheet Title="{Binding HistoryFeedTitle}">
                                <primitives:PropertySheet.PanelContent>
                                    <primitives:ActivityFeed ContentHeight="170" ItemsSource="{Binding RecentActivityItems}" />
                                </primitives:PropertySheet.PanelContent>
                            </primitives:PropertySheet>

                            <primitives:PropertySheet Grid.Column="1" Title="{Binding SnapshotFeedTitle}">
                                <primitives:PropertySheet.PanelContent>
                                    <primitives:SnapshotFeed ContentMaxHeight="170" ItemsSource="{Binding Snapshots}" />
                                </primitives:PropertySheet.PanelContent>
                            </primitives:PropertySheet>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Visibility="{Binding IsInspectorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Background="{StaticResource AppSurfaceBrush}" Padding="12,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding PropertiesTitle}" />
                            <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding PropertiesSubtitle}" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <Button Grid.Column="1" Click="NotYetEditableButton_Click" Padding="6" MinWidth="32" Style="{StaticResource SecondaryToolbarButtonStyle}">
                            <FontIcon Style="{StaticResource AppIcon}" FontSize="18" Glyph="{StaticResource IconClose}" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                        <StackPanel Spacing="12">
                            <primitives:InfoCallout Severity="Info" Title="{Binding InspectorStatusTitle}" Message="{Binding InspectorStatusMessage}" />

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Click="OpenFolderButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                    <primitives:IconText Glyph="{StaticResource IconFolderOpen}" GlyphSize="16" Text="{Binding OpenFolderText}" />
                                </Button>
                                <Button Grid.Column="1" Click="TestPathButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                    <primitives:IconText Glyph="{StaticResource IconTaskAlt}" GlyphSize="16" Text="{Binding TestPathText}" />
                                </Button>
                            </Grid>

                            <primitives:PropertySheet Title="{Binding PropertiesTitle}">
                                <primitives:PropertySheet.PanelContent>
                                    <primitives:KeyValueList ContentMaxHeight="260" ItemsSource="{Binding SelectedItemProperties}" />
                                </primitives:PropertySheet.PanelContent>
                            </primitives:PropertySheet>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Grid>
</Page>
