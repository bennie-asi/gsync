<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.ConflictResolutionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives">
    <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <primitives:SectionHeader Title="{Binding Title}" Subtitle="{Binding ComparisonContext}" />

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <primitives:InfoCallout Severity="Warning" Title="{Binding WarningTitle}" Message="{Binding WarningMessage}" />
            <primitives:InfoCallout Grid.Column="1" Severity="Info" Title="{Binding RiskHintTitle}" Message="{Binding RiskHintMessage}" />
        </Grid>

        <Grid Grid.Row="2" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <primitives:PropertySheet Title="{Binding LocalTitle}">
                    <primitives:PropertySheet.PanelContent>
                        <StackPanel Spacing="12">
                            <primitives:KeyValueList ContentMaxHeight="220" ItemsSource="{Binding LocalVersion}" />
                            <Button Click="UseLocalButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                <primitives:IconText Glyph="{StaticResource IconUpload}" GlyphSize="16" Text="{Binding UseLocalText}" />
                            </Button>
                        </StackPanel>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>

                <primitives:PropertySheet Grid.Column="1" Title="{Binding RemoteTitle}">
                    <primitives:PropertySheet.PanelContent>
                        <StackPanel Spacing="12">
                            <primitives:KeyValueList ContentMaxHeight="220" ItemsSource="{Binding RemoteVersion}" />
                            <Button Click="UseRemoteButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                <primitives:IconText Glyph="{StaticResource IconCloudDone}" GlyphSize="16" Text="{Binding UseRemoteText}" />
                            </Button>
                        </StackPanel>
                    </primitives:PropertySheet.PanelContent>
                </primitives:PropertySheet>
            </Grid>

            <primitives:PropertySheet Grid.Row="1" Title="{Binding BaselineTitle}">
                <primitives:PropertySheet.PanelContent>
                    <primitives:KeyValueList ContentMaxHeight="120" ItemsSource="{Binding SyncBaseline}" />
                </primitives:PropertySheet.PanelContent>
            </primitives:PropertySheet>

            <primitives:ResizableTableView
                x:Name="ConflictFilesTable"
                Grid.Row="2"
                Title="{Binding TableTitle}"
                Subtitle="{Binding TableSubtitle}"
                FooterText="{Binding TableFooterText}"
                PersistedStateKey="conflict-files-table"
                ItemsSource="{Binding ConflictFiles}" />
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Click="KeepBothButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                <primitives:IconText Glyph="{StaticResource IconFileCopy}" Text="{Binding KeepBothText}" />
            </Button>
            <Button Grid.Column="2" Click="ApplyRemoteDecisionsButton_Click" Style="{StaticResource PrimaryToolbarButtonStyle}">
                <primitives:IconText Glyph="{StaticResource IconCheckCircle}" Text="{Binding BackupRestoreText}" />
            </Button>
            <Button Grid.Column="3" Click="CancelButton_Click" Style="{StaticResource SecondaryToolbarButtonStyle}">
                <primitives:IconText Glyph="{StaticResource IconClose}" Text="{Binding CancelText}" />
            </Button>
        </Grid>
    </Grid>
</Page>
