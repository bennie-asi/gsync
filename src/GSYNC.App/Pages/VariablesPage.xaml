<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.VariablesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives">
    <Grid>
        <Grid x:Name="MainContentRoot" Padding="{StaticResource AppPagePadding}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <primitives:SectionHeader Title="{Binding PageTitle}" Subtitle="{Binding PageSubtitle}" />

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <primitives:ToolbarFilterRow
                    SearchPlaceholder="{Binding SearchPlaceholder}"
                    FilterItems="{Binding Filters}"
                    FilterPlaceholder="{Binding FilterPlaceholder}"
                    SelectedFilter="{Binding SelectedScopeFilter, Mode=TwoWay}" />

                <Button Grid.Column="1" Content="{Binding AddVariableText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                <Button Grid.Column="2" Content="{Binding TestTemplateText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="3" Content="{Binding RefreshText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*" MinWidth="680" />
                    <ColumnDefinition Width="360" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <primitives:ResizableTableView
                    x:Name="VariablesTable"
                    Title="{Binding TableTitle}"
                    Subtitle="{Binding TableSubtitle}"
                    FooterText="{Binding TableFooterText}"
                    PersistedStateKey="variables-main-table"
                    ItemsSource="{Binding Variables}" />

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                    <StackPanel Spacing="12">
                        <primitives:PropertySheet Title="{Binding SelectedVariableName}">
                            <primitives:PropertySheet.PanelContent>
                                <StackPanel Spacing="12">
                                    <primitives:KeyValueList ItemsSource="{Binding VariableProperties}" ContentMaxHeight="180" />

                                    <TextBlock FontWeight="SemiBold" Text="{Binding PathTemplateTesterText}" />
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding InputTemplateText}" />
                                    <Border Padding="10" Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                                        <primitives:TooltipTextBlock Text="{Binding TemplateInput}" />
                                    </Border>
                                    <TextBlock Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ResolvedOutputText}" />
                                    <Border Padding="10" Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                                        <primitives:TooltipTextBlock Text="{Binding TemplateOutput}" />
                                    </Border>

                                    <primitives:InfoCallout Title="{Binding OverridePrecedenceTitle}" Message="{Binding OverridePrecedence}" Severity="Info" />
                                </StackPanel>
                            </primitives:PropertySheet.PanelContent>
                        </primitives:PropertySheet>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="{Binding SaveChangesText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                            <Button Grid.Column="1" Content="{Binding ResetText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border
            x:Name="InitializationErrorPanel"
            MaxWidth="720"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppSurfaceAltBrush}"
            BorderBrush="{StaticResource AppDividerBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <StackPanel Spacing="16">
                <primitives:InfoCallout
                    Title="变量页加载失败"
                    Message="Variables 页面初始化出现异常，应用已保留主壳层和导航能力。"
                    Severity="Error" />

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="InitializationErrorTitle"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Variables 初始化失败" />
                    <TextBlock
                        x:Name="InitializationErrorMessage"
                        Foreground="{StaticResource AppTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Content="重试加载"
                    Click="RetryInitialization_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
