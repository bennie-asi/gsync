<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GSYNC.App.Pages.SyncTargetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:GSYNC.App.Primitives"
    xmlns:vm="using:GSYNC.App.ViewModels">
    <Page.Resources>
        <DataTemplate x:Key="SyncTargetRowTemplate" x:DataType="vm:SyncTargetRow">
            <Border BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,0,0,1" Padding="12,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="24" Height="24" Background="{StaticResource AppSurfaceRaisedBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="6" VerticalAlignment="Top">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="{x:Bind DefinitionLabel}" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Name}" />
                            <primitives:Badge Grid.Column="1" Text="{x:Bind Status}" Variant="{x:Bind StatusVariant}" />
                        </Grid>
                        <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Detail}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ConnectionFieldTemplate" x:DataType="vm:UiPropertyRow">
            <StackPanel Spacing="5">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                <Border Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <TextBlock FontSize="12" Text="{x:Bind Value}" TextWrapping="WrapWholeWords" />
                </Border>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="BindingUsageTemplate" x:DataType="vm:UiBindingUsage">
            <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                    <TextBlock FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind Detail}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="TroubleshootingStepTemplate">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Foreground="{StaticResource AppPrimaryBrush}" Text="•" />
                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="StorageFactTemplate" x:DataType="vm:UiPropertyRow">
            <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{x:Bind Label}" />
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind Value}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid x:Name="MainContentRoot" Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <primitives:SearchField Width="220" PlaceholderText="{Binding SearchPlaceholder}" Text="{Binding SearchText, Mode=TwoWay}" />
                    <primitives:FilterDropdown Width="150" ItemsSource="{Binding Filters}" Placeholder="{Binding FilterPlaceholder}" SelectedItem="{Binding SelectedTargetFilter, Mode=TwoWay}" />
                </StackPanel>

                <Button Grid.Column="1" Content="{Binding RefreshText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="2" Content="{Binding TestSelectedText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                <Button Grid.Column="3" Content="{Binding AddTargetText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                <Button Grid.Column="4" Content="{Binding HelpText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="280" />
                    <ColumnDefinition Width="*" MinWidth="520" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Background="{StaticResource AppSurfaceAltBrush}" Padding="12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TargetsCountText}" />
                            <Button Grid.Column="1" Padding="8,6" Style="{StaticResource SecondaryToolbarButtonStyle}">
                                <SymbolIcon Symbol="Add" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <ItemsControl ItemTemplate="{StaticResource SyncTargetRowTemplate}" ItemsSource="{Binding Targets}" />
                        </ScrollViewer>

                        <Grid Grid.Row="2" Background="{StaticResource AppSurfaceAltBrush}" Padding="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TargetsFooterLeftText}" />
                            <TextBlock Grid.Column="1" FontSize="10" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding TargetsFooterRightText}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource AppSurfaceAltBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Background="{StaticResource AppSurfaceBrush}" Padding="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding PaneTitle}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <primitives:Badge Text="{Binding SelectedTargetStatus}" Variant="{Binding SelectedTargetStatusVariant}" />
                                    <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding LastCheckedText}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Padding="14" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <StackPanel Spacing="14">
                                <StackPanel Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}}" Spacing="14">
                                    <primitives:InfoCallout Severity="Error" Title="{Binding FailureTitle}" Message="{Binding FailureMessage}" />
                                    <Border Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AppDangerBrush}" Text="{Binding FailureCodeText}" />
                                            <Button Content="Copy Code" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <primitives:PropertySheet Title="{Binding ConnectionDetailsTitle}">
                                    <primitives:PropertySheet.PanelContent>
                                        <ItemsControl ItemTemplate="{StaticResource ConnectionFieldTemplate}" ItemsSource="{Binding ConnectionFields}" />
                                    </primitives:PropertySheet.PanelContent>
                                </primitives:PropertySheet>

                                <primitives:PropertySheet Title="{Binding ActiveBindingsTitle}" Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                    <primitives:PropertySheet.PanelContent>
                                        <StackPanel Spacing="10">
                                            <TextBlock FontSize="11" Foreground="{StaticResource AppTextDimBrush}" Text="{Binding ActiveBindingsSummaryText}" />
                                            <ItemsControl ItemTemplate="{StaticResource BindingUsageTemplate}" ItemsSource="{Binding ActiveBindings}" />
                                        </StackPanel>
                                    </primitives:PropertySheet.PanelContent>
                                </primitives:PropertySheet>

                                <primitives:PropertySheet Title="{Binding TroubleshootingTitle}" Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <primitives:PropertySheet.PanelContent>
                                        <ItemsControl ItemTemplate="{StaticResource TroubleshootingStepTemplate}" ItemsSource="{Binding TroubleshootingSteps}" />
                                    </primitives:PropertySheet.PanelContent>
                                </primitives:PropertySheet>

                                <primitives:PropertySheet Title="{Binding StorageTitle}" Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <primitives:PropertySheet.PanelContent>
                                        <ItemsControl ItemTemplate="{StaticResource StorageFactTemplate}" ItemsSource="{Binding StorageFacts}" />
                                    </primitives:PropertySheet.PanelContent>
                                </primitives:PropertySheet>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppDividerBrush}" BorderThickness="0,1,0,0" Padding="14,10">
                            <Grid>
                                <Grid Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding RemoveTargetText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="1" Margin="8,0,0,0" Content="{Binding OpenRootText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="3" Content="{Binding TestConnectionText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="4" Margin="8,0,0,0" Content="{Binding SaveChangesText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                                </Grid>
                                <Grid Visibility="{Binding ShowFailureState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding EditCredentialsText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="1" Margin="8,0,0,0" Content="{Binding OpenLogsText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="3" Content="{Binding RetryConnectionText}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                    <Button Grid.Column="4" Margin="8,0,0,0" Content="{Binding SaveChangesText}" Style="{StaticResource PrimaryToolbarButtonStyle}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border
            x:Name="InitializationErrorPanel"
            MaxWidth="720"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource AppSurfaceAltBrush}"
            BorderBrush="{StaticResource AppDividerBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Visibility="Collapsed">
            <StackPanel Spacing="16">
                <primitives:InfoCallout
                    Title="同步目标页加载失败"
                    Message="Sync Targets 页面初始化出现异常，应用已保留主壳层和导航能力。"
                    Severity="Error" />

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="InitializationErrorTitle"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Sync Targets 初始化失败" />
                    <TextBlock
                        x:Name="InitializationErrorMessage"
                        Foreground="{StaticResource AppTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Button
                    Content="重试加载"
                    Click="RetryInitialization_Click"
                    Style="{StaticResource PrimaryToolbarButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
